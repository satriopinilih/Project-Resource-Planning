{
  "name": "project-resource-planning",
  "version": "1.0.0",
  "private": true,
  "description": "Project Resource Planning - Monorepo",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "lint:frontend": "npm run lint --workspace=apps/frontend",
    "dev:backend": "dotnet run --project apps/backend/backend/WebAPI.csproj",
    "build:backend": "dotnet build apps/backend/Backend.slnx",
    "dev": "concurrently --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
